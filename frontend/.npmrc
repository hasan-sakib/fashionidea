# React 19's peer ranges trip npm's strict ERESOLVE resolver on some packages
# (e.g. lucide-react). Accept the valid peers instead of failing the install.
legacy-peer-deps=true

# This environment's path to registry.npmjs.org is very slow (~10s/request).
# Be patient and retry rather than aborting a long install.
fetch-timeout=600000
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
