# Copy to the repo root as .env:  cp docker/.env.example .env
# ---------------------------------------------------------------------------

# --- General -----------------------------------------------------------------
PROJECT_NAME=Fashion Hub
ENVIRONMENT=local
# Apex domain for tenant subdomains (designer1.${DOMAIN}, etc.)
DOMAIN=localhost

# Secret used to sign JWTs in Phase 2. CHANGE THIS for any non-local use.
SECRET_KEY=changethis-super-secret-key

# --- CORS --------------------------------------------------------------------
# Comma-separated. Same-origin requests via Traefik don't need this, but direct
# dev-server access (http://localhost:5173) does.
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173

# --- Database ----------------------------------------------------------------
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fashionhub

# --- Frontend ----------------------------------------------------------------
# Empty = same-origin API calls (Traefik routes /api to the backend on every host).
VITE_API_URL=
